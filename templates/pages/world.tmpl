{{define "title"}}{{.Title}}{{end}}
{{define "bodyclass"}}page page__{{.Slug}}{{end}}

{{define "content"}}
<div class="container">

    <!-- POST FORM -->
    <section class="post-form">
        <form class="post-form__form" action="/mundos/{{.Slug}}" method="post" enctype="multipart/form-data">
            <div class="post-form__profile-pic">
                <img src="/assets/icons/users.svg" alt="Foto de perfil">
            </div>
            <div class="post-form__input">
                <textarea class="post-form__text" name="body" placeholder="Comparte tu experiencia..."></textarea>
                <input type="text" class="post-form__location-input" name="location" placeholder="Ubicación..." style="display:none;">
                <input type="file" id="post-media" name="media" accept="image/*,video/*,.pdf" style="display:none;">
                <div class="post-form__options">
                    <button type="button" class="post-form__upload" aria-label="Subir archivo" onclick="document.getElementById('post-media').click()">
                        <img src="/assets/icons/attach.svg" alt="" aria-hidden="true">
                    </button>
                    <button type="button" class="post-form__location" aria-label="Agregar ubicación" onclick="var i=this.closest('form').querySelector('.post-form__location-input');i.style.display=i.style.display==='none'?'block':'none'">
                        <img src="/assets/icons/location.svg" alt="" aria-hidden="true">
                    </button>
                    <select class="post-form__section-select" name="section_slug">
                        <option value="">Sección</option>
                        {{range .Sections}}
                        <option value="{{.Slug}}">{{.Title}}</option>
                        {{end}}
                    </select>
                    <button type="submit" class="post-form__submit" aria-label="Publicar">
                        <img src="/assets/icons/send.svg" alt="" aria-hidden="true">
                    </button>
                </div>
            </div>
        </form>
    </section>

    <!-- SECTIONS -->
    <section class="sections">
        <div class="sections__list">
            {{range .Sections}}
            <a class="sections__item card" id="{{.Slug}}" href="{{.Path}}">
                <h3 class="sections__item-title">{{.Title}}</h3>
            </a>
            {{end}}
        </div>
    </section>

    <!-- MIS PUBLICACIONES -->
    <section class="post-list">
        <h2 class="post-list__title">Mis Publicaciones</h2>
        <ul id="my-posts" class="post-list__items" data-world="{{.Slug}}"></ul>
    </section>

    <!-- PUBLICACIONES DE OTROS USUARIOS -->
    <section class="post-list">
        <h2 class="post-list__title">Publicaciones de otros usuarios</h2>
        <ul id="other-posts" class="post-list__items"></ul>
    </section>

</div>

<!-- PLANTILLA DE CARD (invisible hasta que JS la clona) -->
<template id="post-tpl">
    <li class="post-list__item">
        <article class="post card">
            <header class="post__header">
                <p class="post__user"></p>
                <p class="post__title"></p>
            </header>
            <div class="post__content">
                <p class="post__text"></p>
                <img class="post__media" alt="Archivo adjunto" hidden>
            </div>
            <footer class="post__footer">
                <p class="post__location" hidden></p>
                <p class="post__date"></p>
                <div class="post__actions" hidden>
                    <button class="btn btn--edit" type="button">Editar</button>
                    <button class="btn btn--delete" type="button">Borrar</button>
                </div>
            </footer>
        </article>
    </li>
</template>

<script src="/assets/js/posts.js" defer></script>
{{end}}
