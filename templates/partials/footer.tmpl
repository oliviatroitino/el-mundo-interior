{{define "footer"}}
<footer class="footer">
    <div class="container footer__container">
        <div class="footer-columns">
            <h3>Sobre nosotros</h3>
            <ul class="footer-columns__list footer-columns__list--about" id="about">
                <li class="footer-columns__item">Empresa verificada: Introspecta Labs S.L. (CIF B12345678)</li>
                <li class="footer-columns__item">Privacidad y cookies: Cumplimos RGPD y protegemos tus datos con cifrado SSL</li>
                <li class="footer-columns__item">Contacto directo: +34 123 456 789 | soporte@introspecta.es</li>
            </ul>
        </div>
        <form class="footer__contact" action="/contacto" method="post">
            <h2 class="footer__contact-title">Contacto</h2>
            <div class="footer__contact-field">
                <label class="footer__contact-label" for="footer-name">Nombre</label>
                <input class="footer__contact-input" type="text" id="footer-name" name="name" required>
            </div>
            <div class="footer__contact-field">
                <label class="footer__contact-label" for="footer-email">Correo</label>
                <input class="footer__contact-input" type="email" id="footer-email" name="email" required>
            </div>
            <div class="footer__contact-field">
                <label class="footer__contact-label" for="footer-message">Mensaje</label>
                <textarea class="footer__contact-textarea" id="footer-message" name="message" required></textarea>
            </div>
            <button class="footer__contact-button" type="submit">Enviar</button>
        </form>
    </div>
</footer>
{{end}}